<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="awesome_owl.counter">
        <div class="card d-inline-block p-2">
            <a>Counter: <t t-esc="state.value"/></a>
            <button class="btn btn-primary bg-primary text-white border ms-2" type="button" t-on-click="increment">Increment</button>
        </div>
    </t>

</templates>